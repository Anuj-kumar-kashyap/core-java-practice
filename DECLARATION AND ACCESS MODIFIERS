import java.util.*;
import java.sql.*;;

class A {

    public static void main(String[] args) {
        Date d = new Date();
        
    }
}
//This date class is present in both above imported packages, but we compile this program we get an erro
//error: reference to Date is ambiguous, both class java.squl.Date in java.sql and class java.util.Date in java.util match
//So here neither the date of sql and nor the date of util will be considered

import java.util.Date;
import java.sql.*;;

class A {

    public static void main(String[] args) {
        Date d = new Date();//Here this Date is the object of util package.
        
    }
}
//Here it compile successfully because for util package we are using Explicit import statement and it has more priority than implicity which is java.sql

Current working directory: If we create two files in one folder(directory), then method created in a class can be called in another file's class by creating an object of method class.

class A{
    public void m1() {
        System.out.println("helo");
    }
}

class B{
    public static void main(String[] args) {
        A a = new A();
        a.m1();// it prints helo 
    }
}
//Here both the files in same directory that's why they executes without importing the class.

