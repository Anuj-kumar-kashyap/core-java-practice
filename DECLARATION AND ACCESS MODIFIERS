----------------------------
public class A {
    public static void main(String[] args) {
        java.util.ArrayList l = new  java.util.ArrayList();//we can import package in this way also this way names as: fully Qualified name
    }
}
we don't need to import the (java.lang & current working directory) package manually, they are already imported.
import java.util.ArrayList; // Explicit: Here we exactly define the class which we need.
import java.util.* // Implicit (* means so many classes) Here compiler search by itself that where the needed class is present So it is time consuming.
Explicit import statement have more priority over the Implicit.

import java.util;// Invalid
import java.util.ArrayList.*;// Invalid
import java.util.*;// Valid
import java.util.ArrayList;// Valid

class A extends java.util.ArrayList{
    
}
//If a needed class is inheritable then we can import that class like this using extends keyword without import statement
